pestaña 2 

class Movil {
  PVector pos, vel;
  int r;
  Movil(float x, float y) {
    pos = new PVector(x, y);
    vel = new PVector(random(-2, 2), random(-2, 2));
    r = 30; 
  }
  Movil(float x, float y, float vx, float vy) {
    pos = new PVector(x, y);
    vel = new PVector(vx, vy);
    r = 30;
  }
  void mover() {
    pos.add(vel);
    contener();
  }
  void mostrar() {
    fill(100, 150, 250);
    ellipse(pos.x, pos.y, r, r);
  }
  void contener() {
    if (pos.x < 0 || pos.x > width) {
      pos.sub(vel);
      vel.x = vel.x * -1;
    }
    if (pos.y < 0 || pos.y > height) {
      pos.sub(vel); 
      vel.y = vel.y * -1;
    }
  }
}

